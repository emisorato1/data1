# =============================================================================
# .dockerignore for Airflow custom image build
# =============================================================================
# Exclude unnecessary files from Docker build context
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
dist/
build/

# IDE
.vscode
.idea
*.swp
*.swo

# Documentation
*.md
LICENSE

# Scripts (we only need requirements.txt in the image)
scripts/
