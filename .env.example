# ==============================================================================
# Variables de entorno — Desarrollo local
# Copiar a .env y completar los valores marcados con CHANGE_ME
# ==============================================================================

# --- PostgreSQL (local via docker compose) ------------------------------------
DB_NAME=rag_db
DB_USER=raguser
DB_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://raguser:CHANGE_ME_strong_password@localhost:5432/rag_db

# --- Redis (local via docker compose) ----------------------------------------
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379/0

# --- Langfuse (cluster K8s compartido) ----------------------------------------
# Langfuse NO se levanta localmente. Conectarse al cluster compartido:
#   1. Port-forward: kubectl port-forward svc/langfuse-web 3000:3000 -n langfuse
#   2. Crear proyecto en la UI y obtener API keys
#   3. Ver infra/langfuse/README.md para instrucciones completas
LANGFUSE_HOST=http://localhost:3000/
LANGFUSE_BASE_URL=http://localhost:3000/
LANGFUSE_PUBLIC_KEY=pk-lf-9e93b81c-7e78-4de9-a82d-d4fd580bfff6
LANGFUSE_SECRET_KEY=sk-lf-21aa7e7c-5313-4745-9382-489c864adc11

# --- Airflow ------------------------------------------------------------------
# OPCION A: Airflow local (recomendado para desarrollo de DAGs)
#   Activar con: docker compose --profile airflow up
#   UI: http://localhost:8080 (credenciales en stdout del primer arranque)
#   Los DAGs se montan desde ./dags/ via bind mount
AIRFLOW_API_URL=http://localhost:8080
#
# OPCION B: Airflow del cluster K8s compartido (cuando este disponible)
# Airflow NO se levanta localmente. Conectarse al cluster compartido:
#   1. Port-forward: kubectl port-forward svc/airflow-api-server 8080:8080 -n airflow
#   2. Airflow 3 usa api-server (no webserver). Ver infra/airflow/README.md
#   3. URL interna desde pods: http://airflow-api-server.airflow.svc.cluster.local:8080
# AIRFLOW_API_URL=http://localhost:8080

# --- Google Cloud / Vertex AI -------------------------------------------------
USE_VERTEX_AI=true
GEMINI_API_KEY=AQ.Ab...
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=itmind-macro-ai-dev-0
GCP_LOCATION=us-east1
# Opcional: proyecto de cuota GCP para ADC de usuario (elimina UserWarning al iniciar).
# Si no se define, se usa GCP_PROJECT_ID como fallback.
GCP_QUOTA_PROJECT_ID=

# NOTA: NO se usan service account keys (politica org: "Deny SA key creation").
# Autenticarse con ADC (Application Default Credentials) via OAuth:
#   gcloud auth application-default login --project=<PROJECT_ID>
# Esto crea ~/.config/gcloud/application_default_credentials.json
# que se monta automaticamente en el contenedor de Airflow.
# Ver README.md seccion "Autenticacion con Google Cloud" para mas detalle.

# --- Auth --------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_min_32_chars

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# --- Frontend ----------------------------------------------------------------
# URL directa del backend para SSE streaming en el browser (bypassa proxy Next.js)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# URL interna para el Route Handler proxy (server-side, container-to-container)
# En desarrollo local sin Docker no es necesaria (fallback a NEXT_PUBLIC_BACKEND_URL)
# BACKEND_INTERNAL_URL=http://backend:8000

# --- App ----------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# --- Retrieval tuning (T3-S4-02) ---------------------------------------------
# ef_search: HNSW precision. 40=fast, 100=balanced, 200=high, 400=max
RETRIEVAL_EF_SEARCH=100
# RRF weights: balance vector vs BM25 (1.0/1.0 = equal)
RETRIEVAL_VECTOR_WEIGHT=1.0
RETRIEVAL_BM25_WEIGHT=1.0
# RRF smoothing constant (60 = literature standard)
RETRIEVAL_RRF_K=60
# Chunks after hybrid fusion (input to reranker)
RETRIEVAL_TOP_K=20
# Chunks after reranking (input to generation)
RERANKER_TOP_K=5
