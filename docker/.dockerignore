# ==============================================================================
# .dockerignore — Excluir del contexto de build Docker
# Ref: T1-S3-01 AC: excluye .git, tests, docs, __pycache__, dags/
# ==============================================================================

# --- Version control ---
.git
.gitignore

# --- Tests y QA ---
tests/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Documentacion ---
docs/
*.md

# --- Python caches ---
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class

# --- Airflow DAGs (no van en imagen de API) ---
dags/

# --- Entornos virtuales ---
.venv/
venv/
ENV/

# --- Environment y secrets (NUNCA en imagen) ---
.env
.env.*
!.env.example
*-secrets.yaml

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Node / Frontend ---
node_modules/
.next/

# --- Docker (evitar recursion) ---
docker-compose*.yml
docker/Dockerfile
docker/.dockerignore

# --- Build artifacts ---
dist/
build/
*.egg-info/
*.egg
*.whl

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
Thumbs.db

# --- Misc proyecto ---
.mypy_cache/
.ruff_cache/
.benchmarks/
specs/
infra/
scripts/
.opencode/
.claude/
.agent/
.github/
